// Prisma schema for basheer.app
//
// Phase 1: just the ContactSubmission table (lead intake from /contact).
// More models (Project, Article, User, etc.) will be added in later phases
// as the file-based MDX CMS moves into the DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ContactSubmission ────────────────────────────────────────────────────────
// Every submission from /contact lands here. Status lets the admin mark a
// lead as read / replied / closed later without deleting anything.

enum ContactStatus {
  NEW
  READ
  REPLIED
  CLOSED
  SPAM
}

// ── SiteSetting ──────────────────────────────────────────────────────────────
// Key-value store that lets the cockpit override site content without a
// deploy. Code-side defaults apply when a key is absent, so the public site
// never depends on the DB being reachable.

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ── AI assistant (cockpit) ───────────────────────────────────────────────────
// Conversations with the cockpit assistant. Provider-agnostic: the model name
// is stored per message so history survives provider swaps.

model AiConversation {
  id        String      @id @default(cuid())
  title     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AiMessage[]

  @@index([updatedAt(sort: Desc)])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           String
  content        String         @db.Text
  model          String?
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model ContactSubmission {
  id        String        @id @default(cuid())
  name      String
  email     String
  company   String?
  budget    String?
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([email])
}
