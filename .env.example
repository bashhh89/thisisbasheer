# ── Cockpit (/admin) ─────────────────────────────────────────────────────────
# Postgres connection for content overrides, leads inbox, and AI history
DATABASE_URL=postgresql://user:pass@host:5432/basheer
# Cockpit login password (required for /admin)
ADMIN_PASSWORD=
# Optional separate secret for session signing (falls back to ADMIN_PASSWORD)
ADMIN_SESSION_SECRET=

# ── Assistant (provider-agnostic, OpenAI-compatible) ─────────────────────────
# Any OpenAI-compatible chat-completions endpoint (Ollama cloud, LiteLLM, ...)
AI_BASE_URL=
AI_API_KEY=
